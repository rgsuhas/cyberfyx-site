---
import BrandLogo from './BrandLogo.astro';
import { fetchContactProfile } from '../lib/api';
import { FOOTER_LINK_GROUPS } from '../data/footer-links';
import { CONTACT_PROFILE_FALLBACK } from '../lib/fallbacks';

const profile = (await fetchContactProfile()) ?? CONTACT_PROFILE_FALLBACK;
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <BrandLogo imageHeight={50} />
        <p>Globally trusted leader in cybersecurity and smart IT management.</p>
        {profile.office_regions.length > 0 && (
          <div class="office-regions">
            {profile.office_regions.map(r => (
              <span class="region-badge">{r.label}</span>
            ))}
          </div>
        )}
      </div>

      {FOOTER_LINK_GROUPS.map((group) => (
        <div>
          <h4 class="footer-heading">{group.heading}</h4>
          <ul class="footer-links">
            {group.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <div>
        <h4 class="footer-heading">Contact Us</h4>
        <ul class="footer-links footer-contact">
          <li>
            <i class="fa-solid fa-location-dot"
               onclick={`window.open('${profile.map_url}', '_blank')`}
               style="margin-top: 5px; color: var(--accent-primary); cursor: pointer;"></i>
            <span set:html={profile.headquarters_address.replace(', ', ',<br>')}></span>
          </li>
          <li>
            <i class="fa-solid fa-envelope" style="margin-top: 5px; color: var(--accent-primary);"></i>
            <a href={`https://mail.google.com/mail/?view=cm&fs=1&to=${profile.sales_email}`} target="_blank">
              {profile.sales_email}
            </a>
          </li>
          <li>
            <i class="fa-solid fa-phone" style="margin-top: 5px; color: var(--accent-primary);"></i>
            <a href={`tel:${profile.primary_phone.replace(/\s/g, '')}`}>{profile.primary_phone}</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      &copy;{new Date().getFullYear()} Cyberfyx. All rights reserved.
    </div>
  </div>
</footer>

<!-- Back to Top Button -->
<a href="#top" id="back-to-top" class="back-to-top" aria-label="Back to Top">
  <i class="fa-solid fa-arrow-up"></i>
</a>
