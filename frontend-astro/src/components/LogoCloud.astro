---
import InfiniteSlider from './ui/InfiniteSlider.astro';

interface Logo {
  src: string;
  alt: string;
  width?: number;
  height?: number;
}

interface Props {
  logos: Logo[];
  title?: string;
  speed?: number;
  speedOnHover?: number;
  reverse?: boolean;
  class?: string;
}

const {
  logos,
  title,
  speed = 80,
  speedOnHover = 25,
  reverse = false,
  class: className = "",
} = Astro.props;
---

<section class={`logo-cloud ${className}`}>
  {title && <h2 class="logo-cloud-title">{title}</h2>}
  
  <div class="logo-cloud-container">
    <InfiniteSlider
      gap={42}
      reverse={reverse}
      speed={speed}
      speedOnHover={speedOnHover}
      class="logo-cloud-slider"
    >
      {logos.map((logo) => (
        <div class="logo-item">
          <img
            alt={logo.alt}
            src={logo.src}
            width={logo.width}
            height={logo.height}
            loading="lazy"
            class="logo-image"
          />
        </div>
      ))}
    </InfiniteSlider>
  </div>
</section>

<script>
  // Handle responsive animation on resize
  let lastWidth = window.innerWidth;
  let resizeTimeout: NodeJS.Timeout | null = null;
  
  function adjustAnimationSpeed() {
    const sliders = document.querySelectorAll('.infinite-slider');
    
    sliders.forEach((slider) => {
      const content = slider.querySelector('.infinite-slider-content');
      if (!content) return;
      
      const contentWidth = content.scrollWidth;
      const gap = parseFloat(
        getComputedStyle(slider).getPropertyValue('--gap') || 42
      );
      
      // Calculate duration based on content width to keep consistent speed
      // Base: ~100px per second for smoother, slower scrolling
      const duration = Math.max(120, (contentWidth + gap) / 100);
      
      slider.style.setProperty('--animation-duration', `${duration}s`);
    });
  }
  
  // Debounced resize handler - only recalculate on significant viewport changes
  function debouncedResize() {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    
    resizeTimeout = setTimeout(() => {
      const currentWidth = window.innerWidth;
      // Only adjust if viewport changed by more than 50px
      if (Math.abs(currentWidth - lastWidth) > 50) {
        lastWidth = currentWidth;
        adjustAnimationSpeed();
      }
    }, 250); // Wait 250ms after resize stops
  }
  
  // Adjust on load
  if (typeof window !== 'undefined') {
    adjustAnimationSpeed();
    
    // Only listen to window resize with debouncing
    window.addEventListener('resize', debouncedResize);
  }
</script>

<style>
  .logo-cloud {
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    padding: 1.5rem 0;
    background: linear-gradient(
      135deg,
      #F5A85F 0%,
      #F9BC7F 50%,
      #F5A85F 100%
    );
    border-top: 1px solid rgba(245, 168, 95, 0.35);
    border-bottom: 1px solid rgba(245, 168, 95, 0.35);
  }

  .logo-cloud-title {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2.5rem;
    color: #ffffff;
    letter-spacing: -0.02em;
  }

  .logo-cloud-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    /* Gradient mask for smooth fade effect at edges */
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 20%,
      black 80%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 20%,
      black 80%,
      transparent 100%
    );
  }

  :global(.logo-cloud-slider) {
    /* Ensures smooth scrolling performance */
    will-change: transform;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    height: 100px;
    padding: 1rem 2rem;
    transition: all var(--transition-normal);
    border-radius: 12px;
    border: none;
    background: transparent;
    backdrop-filter: none;
    box-shadow: none;
  }

  .logo-item:hover {
    border-color: transparent;
    background: transparent;
    box-shadow: none;
  }

  .logo-image {
    max-height: 60px;
    max-width: 180px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    user-select: none;
    pointer-events: none;
    /* Brighter logos */
    filter: brightness(1.1) contrast(1.15) drop-shadow(0 1px 2px rgba(53, 29, 117, 0.15));
    transition: filter var(--transition-fast);
  }

  .logo-item:hover .logo-image {
    filter: brightness(1.2) contrast(1.25) drop-shadow(0 2px 4px rgba(53, 29, 117, 0.2));
  }

  /* Dark mode adjustments */
  [data-theme="dark"] .logo-cloud {
    background: linear-gradient(
      135deg,
      #6b4d8f 0%,
      #7a5fa3 50%,
      #6b4d8f 100%
    );
    border-top-color: rgba(196, 169, 214, 0.25);
    border-bottom-color: rgba(196, 169, 214, 0.25);
  }

  [data-theme="dark"] .logo-cloud-title {
    color: #ffffff;
  }

  [data-theme="dark"] .logo-item {
    background: rgba(53, 29, 117, 0.7);
    border-color: rgba(196, 169, 214, 0.2);
  }

  [data-theme="dark"] .logo-item:hover {
    background: rgba(53, 29, 117, 0.9);
    border-color: rgba(196, 169, 214, 0.4);
  }

  [data-theme="dark"] .logo-image {
    filter: brightness(1.15) invert(0.8) drop-shadow(0 1px 2px rgba(53, 29, 117, 0.2));
  }

  [data-theme="dark"] .logo-item:hover .logo-image {
    filter: brightness(1.25) invert(0.9) drop-shadow(0 2px 4px rgba(196, 169, 214, 0.25));
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .logo-cloud {
      padding: 2rem 0;
    }

    .logo-cloud-title {
      font-size: 1.25rem;
      margin-bottom: 2rem;
    }

    .logo-item {
      height: 80px;
      padding: 0.75rem 1.25rem;
      border-radius: 8px;
      border-width: 1px;
    }

    .logo-image {
      max-height: 48px;
      max-width: 140px;
    }
  }
</style>
