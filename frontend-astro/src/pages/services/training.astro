---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Cybersecurity Training | Cyberfyx">
  <section style="padding-top: 100px; padding-bottom: 60px;">
    <div class="container">
      <div class="grid grid-2" style="align-items: center; gap: 4rem;">
        <div class="fade-up">
          <h1 style="margin-bottom: 1.5rem;">Cybersecurity Training</h1>
          <p style="font-size: 1.1rem; margin-bottom: 2rem; line-height: 1.8; color: var(--text-secondary);">Empower your workforce with the knowledge and skills needed to recognize and prevent cyber attacks before they impact your business.</p>
        
        </div>
        <div class="glass-card fade-up delay-100" style="text-align: center; padding: 4rem;">
          <i class="fa-solid fa-chalkboard-user" style="font-size: 6rem; color: var(--accent-secondary);"></i>
        </div>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header fade-up">
        <h2>Our <span class="text-gradient">Training Programs</span></h2>
      </div>
      
      <div class="grid grid-2" style="gap: 2rem; margin-bottom: 4rem;">
        
        <div class="glass-card fade-up" style="padding: 2.5rem; border-left: 4px solid var(--accent-primary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">ISO/IEC 27001:2022 Awareness & Internal Audit</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>2 Days</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> ISMS implementers, audit teams</p>
        </div>

        <div class="glass-card fade-up delay-100" style="padding: 2.5rem; border-left: 4px solid var(--accent-secondary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">GDPR Compliance Workshop</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>1 Day</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> DPOs, IT, legal, marketing teams</p>
        </div>

        <div class="glass-card fade-up" style="padding: 2.5rem; border-left: 4px solid var(--accent-primary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">HIPAA Security & Privacy</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>1 Day</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> Healthcare IT teams</p>
        </div>

        <div class="glass-card fade-up delay-100" style="padding: 2.5rem; border-left: 4px solid var(--accent-secondary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">PCI DSS Readiness Training</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>1 Day</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> Payment service teams</p>
        </div>

        <div class="glass-card fade-up" style="padding: 2.5rem; border-left: 4px solid var(--accent-primary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">SOC 2 & SOC 1 Compliance Foundation</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>1 Day</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> SaaS businesses, audit teams</p>
        </div>

        <div class="glass-card fade-up delay-100" style="padding: 2.5rem; border-left: 4px solid var(--accent-secondary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">NIST CSF & Risk Management Framework</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Advanced</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>2 Days</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> Government, finance, critical infra</p>
        </div>

        <div class="glass-card fade-up" style="padding: 2.5rem; border-left: 4px solid var(--accent-primary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">IT Governance (COBIT & ITIL v4) Awareness</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>1 Day</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> IT managers, auditors</p>
        </div>

        <div class="glass-card fade-up delay-100" style="padding: 2.5rem; border-left: 4px solid var(--accent-secondary); display: flex; flex-direction: column; justify-content: space-between;">
          <div>
            <h3 style="margin-bottom: 1rem; font-size: 1.25rem;">Business Continuity & Disaster Recovery</h3>
            <div style="display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
              <span style="background: rgba(var(--accent-primary-rgb), 0.1); color: var(--accent-primary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-solid fa-signal" style="margin-right: 5px;"></i>Intermediate</span>
              <span style="background: rgba(var(--accent-secondary-rgb), 0.1); color: var(--accent-secondary); padding: 0.25rem 0.75rem; border-radius: 50px; font-size: 0.85rem; font-weight: 600;"><i class="fa-regular fa-clock" style="margin-right: 5px;"></i>1 Day</span>
            </div>
          </div>
          <p style="color: var(--text-secondary); margin: 0; font-size: 0.95rem;"><strong>For:</strong> Risk managers, compliance leads</p>
        </div>
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/services" class="btn btn-outline"><i class="fa-solid fa-arrow-left"></i> Back to All Services</a>
      </div>
    </div>
  </section>
</BaseLayout>
