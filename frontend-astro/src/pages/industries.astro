---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Industries We Protect | Cyberfyx"
  description="Cyberfyx delivers tailored cybersecurity and IT governance frameworks for diverse sectors including healthcare, finance, manufacturing, and more."
>
  <!-- Industries Section -->
  <section id="industries" style="padding-top: 100px; background: var(--bg-secondary);">
    <div class="container">
      <div class="section-header fade-up">
        <h2>Industries We <span class="text-gradient">Protect</span></h2>
        <p>Tailored cybersecurity and IT governance frameworks built for specific sector requirements.</p>
      </div>

      <div class="grid grid-4 industries-grid" style="gap: 2rem;">
        <div class="glass-card industry-card fade-up">
          <div class="service-icon"><i class="fa-solid fa-notes-medical"></i></div>
          <h4>Healthcare</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-100">
          <div class="service-icon"><i class="fa-solid fa-building-columns"></i></div>
          <h4>Banking & Finance</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-200">
          <div class="service-icon"><i class="fa-solid fa-cart-shopping"></i></div>
          <h4>Retail & E-Commerce</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-300">
          <div class="service-icon"><i class="fa-solid fa-industry"></i></div>
          <h4>Manufacturing</h4>
        </div>

        <div class="glass-card industry-card fade-up">
          <div class="service-icon"><i class="fa-solid fa-graduation-cap"></i></div>
          <h4>Education & EdTech</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-100">
          <div class="service-icon"><i class="fa-solid fa-plane-departure"></i></div>
          <h4>Defense & Aerospace</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-200">
          <div class="service-icon"><i class="fa-solid fa-network-wired"></i></div>
          <h4>Information Technology</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-300">
          <div class="service-icon"><i class="fa-solid fa-plug-circle-bolt"></i></div>
          <h4>Energy & Utilities</h4>
        </div>
        <div class="glass-card industry-card fade-up">
          <div class="service-icon"><i class="fa-solid fa-landmark-dome"></i></div>
          <h4>Government & Public Sector</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-100">
          <div class="service-icon"><i class="fa-solid fa-tower-cell"></i></div>
          <h4>Telecom</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-200">
          <div class="service-icon"><i class="fa-solid fa-truck-arrow-right"></i></div>
          <h4>Transport & Logistics</h4>
        </div>
        <div class="glass-card industry-card fade-up delay-300">
          <div class="service-icon"><i class="fa-solid fa-photo-film"></i></div>
          <h4>Media & Entertainment</h4>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section style="text-align: center;">
    <div class="container">
      <div class="fade-up">
        <h2 style="margin-bottom: 1rem;">Find Your <span class="text-gradient">Industry Security Solution</span></h2>
        <p style="font-size: 1.1rem; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">Connect with our team to discuss industry-specific security challenges and discover how our tailored solutions address your sector's unique requirements.</p>
        <a href="/contact" class="btn btn-primary hero-btn" style="min-width: 220px; padding: 1rem 2rem;">
          <span>Talk to Our Industry Expert</span>
          <i class="fa-solid fa-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
