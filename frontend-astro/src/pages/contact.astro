---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import { fetchContactProfile } from '../lib/api';

const FALLBACK_CONTACT = {
  sales_email: 'sales@cyberfyx.net',
  primary_phone: '+91 9663410308',
  headquarters_name: 'Cyberfyx Headquarters',
  headquarters_address: 'Janardhana Towers, Ashok Nagar, Bengaluru 560025',
  map_url: 'https://maps.google.com/?q=Janardhana+Towers+Ashok+Nagar+Bengaluru+560025',
  interest_options: [
    { slug: 'cybersecurity-services', label: 'Cybersecurity' },
    { slug: 'it-security-and-continuity', label: 'IT Security' },
    { slug: 'endpoint-management-services', label: 'Endpoint Management' },
    { slug: 'core-industry-services', label: 'Core Industry Services' },
    { slug: 'training', label: 'Training' },
    { slug: 'general-inquiry', label: 'General Inquiry' },
  ],
};

const profile = (await fetchContactProfile()) ?? FALLBACK_CONTACT;
const telHref = `tel:${profile.primary_phone.replace(/[^+\d]/g, '')}`;
---

<BaseLayout 
  title="Contact Cyberfyx | Start a Security Conversation"
  description="Whether you need an immediate cybersecurity assessment, managed endpoint services, or ISO consultation, our team is ready to assist you."
>
  <section id="contact" class="section pt-4">
    <div class="container">
      <div class="grid grid-2 gap-3" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
        <div class="fade-up">
            <h1 class="mb-2">Get in <span class="text-gradient">Touch</span></h1>
            <p class="lede mb-3">Whether you need an immediate cybersecurity assessment, managed endpoint services, or ISO consultation, our team is ready to assist you.</p>

            <div class="flex gap-1 mb-2">
                <div class="service-icon" style="flex-shrink: 0; width: 50px; height: 50px;">📍</div>
                <div>
                    <h4 class="mb-1">Office Location</h4>
                    <p>
                      <a href={profile.map_url} target="_blank" rel="noopener noreferrer">{profile.headquarters_name}</a><br />
                      {profile.headquarters_address}
                    </p>
                </div>
            </div>

            <div class="flex gap-1 mb-2">
                <div class="service-icon" style="flex-shrink: 0; width: 50px; height: 50px;">📞</div>
                <div>
                    <h4 class="mb-1">Phone Number</h4>
                    <p><a href={telHref}>{profile.primary_phone}</a></p>
                </div>
            </div>

            <div class="flex gap-1 mb-2">
                <div class="service-icon" style="flex-shrink: 0; width: 50px; height: 50px;">✉️</div>
                <div>
                    <h4 class="mb-1">Email Address</h4>
                    <p><a href={`mailto:${profile.sales_email}`}>{profile.sales_email}</a></p>
                </div>
            </div>
        </div>

        <ContactForm interestOptions={profile.interest_options} />

      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import '../scripts/animations.ts';
  import '../scripts/contact-form.ts';
</script>
