# ── Core ──────────────────────────────────────────────────────────────────────
CYBERFYX_ENVIRONMENT=production
CYBERFYX_DEBUG=false
CYBERFYX_APP_NAME=Cyberfyx Backend

# ── Database ───────────────────────────────────────────────────────────────────
# Neon PostgreSQL: get connection string from Neon dashboard → Connection Details
# Use the "pooled" connection string for better performance on Render free tier.
# Format: postgresql+psycopg2://user:password@host.neon.tech/dbname?sslmode=require
CYBERFYX_DATABASE_URL=postgresql+psycopg2://user:password@host.neon.tech/dbname?sslmode=require

# Local SQLite (development only):
# CYBERFYX_DATABASE_URL=sqlite:///./cyberfyx.db

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Add your Render frontend URL and/or custom domain.
CYBERFYX_CORS_ORIGINS=https://your-frontend.onrender.com,https://yourdomain.com

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
CYBERFYX_JWT_SECRET_KEY=replace-with-long-random-secret
CYBERFYX_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Internal / Admin API ───────────────────────────────────────────────────────
# Set true to enable the /admin panel and /api/v1/internal/* routes.
CYBERFYX_ENABLE_INTERNAL_API=true

# ── Bootstrap Admin User ───────────────────────────────────────────────────────
# Created automatically on first startup. Change the password after first login.
CYBERFYX_BOOTSTRAP_STAFF_EMAIL=admin@yourdomain.com
CYBERFYX_BOOTSTRAP_STAFF_PASSWORD=change-this-after-first-login

# ── Rate Limiting ──────────────────────────────────────────────────────────────
CYBERFYX_INQUIRY_RATE_LIMIT_WINDOW_MINUTES=15
CYBERFYX_INQUIRY_RATE_LIMIT_COUNT=5
CYBERFYX_INQUIRY_DUPLICATE_WINDOW_HOURS=24

# ── SMTP (optional — required for email notifications) ─────────────────────────
CYBERFYX_SMTP_HOST=
CYBERFYX_SMTP_PORT=587
CYBERFYX_SMTP_USERNAME=
CYBERFYX_SMTP_PASSWORD=
CYBERFYX_SMTP_USE_TLS=true
CYBERFYX_SMTP_FROM_EMAIL=
CYBERFYX_SMTP_SALES_TO=sales@cyberfyx.net

# ── Startup Behaviour ──────────────────────────────────────────────────────────
# Both default to true. Set false to skip on restart (safe to leave true — seed is idempotent).
CYBERFYX_RUN_MIGRATIONS_ON_START=true
CYBERFYX_RUN_SEED_ON_START=true
